{
    "FormatVersion": "3.00",
    "DataVersion": "3.00",
    "Objects": {
        "Component_CpuBoard": {
            "FruId": 255,
            "Instance": 255,
            "Type": 36,
            "Name": "CpuBoard${Slot}",
            "Presence": 1,
            "Health": 0,
            "PowerState": 1,
            "GroupId": 1,
            "UniqueId": "N/A",
            "BoardId": 65535,
            "ReplaceFlag": 0,
            "PreviousSN": "",
            "SerialNumber": "",
            "NodeId": "BCU CpuBoard",
            "Location": "BCU${Slot}"
        },
        "BoardRAS_1": {
            "ManageChip": "Mcu",
            "Name": "CpuBoard${Slot}",
            "GetLenthCmd": "#/Accessor_GetFlashSize.Value",
            "SetStartPosCmd": "#/Accessor_SetFlashReadPos.Value",
