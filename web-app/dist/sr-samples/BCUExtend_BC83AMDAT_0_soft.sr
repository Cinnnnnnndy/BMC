        },
        "Event_Cpld1Selfcheck": {
            "Reading": "<=/Scanner_Cpld1Status.Value",
            "OperatorId": 5,
            "Enabled": true,
            "DescArg1": "1",
            "DescArg2": "${Slot}",
            "@Default":{
                "Reading": 255
              },
              "InvalidReadingIgnore": 1,
              "InvalidReading": 255,
            "Component": "#/Component_CpuBoard",
            "AdditionalInfo": "1,2"
        },
        "Event_MemoryAccessPowerFail": {
            "Reading": "<=/Scanner_MemPwrSensorStatus.Value;<=/Scanner_PowerGood.Value |> expr($2 == 0 ? 0 : $1)",
