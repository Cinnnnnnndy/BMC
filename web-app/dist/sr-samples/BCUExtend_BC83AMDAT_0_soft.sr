            "Enabled": true,
            "DescArg1": "Memory",
            "DescArg2": "${Slot}",
            "AdditionalInfo": "1,2",
            "Component": "#/Component_CpuBoard"
        },
        "Event_MemoryAccessPowerInvalid": {
            "Reading": "<=/Scanner_MemPower.Value;<=/Scanner_MemPwrSensorStatus.Value;<=/Scanner_PowerGood.Value |> expr(($2 == 1 || $3 == 0) ? 0 : $1 * 0.125)",
