        "Scanner_Fan_Pwr": {"Value": "expr($adc_fan_2_high + ($adc_fan_1_low << 8))"},
        "Scanner_SEU_1": {"Value": "expr($prsnt_front_hdd)"},
        "Scanner_SEU_2": {"Value": "expr($prsnt_psu_hdd)"},
        "Scanner_PowerBtnEvt": {"Value": "expr($fp_power_button_event)"},
