      "Mapping": {
        "Scanner_SerdesLom1Pres": {"Value": "expr($nic1_prsnt)"},
        "Scanner_SerdesLom2Pres": {"Value": "expr($nic2_prsnt)"},
        "Scanner_PS1Pres": {"Value": "expr($psu1_cpld_prsnt)"},
